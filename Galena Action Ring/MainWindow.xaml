<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Galena_Action_Ring.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Galena_Action_Ring">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="AppRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- App Title Bar -->
        <Border x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Hamburger Button -->
                <Button
                    x:Name="HamburgerButton"
                    Grid.Column="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="48" Height="48"
                    Click="HamburgerButton_Click">
                    <FontIcon FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined" Glyph="&#xE5D2;" FontSize="16" />
                </Button>

                <!-- Back Button -->
                <Button
                    x:Name="BackButton"
                    Grid.Column="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="48" Height="48"
                    IsEnabled="False">
                    <FontIcon FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined" Glyph="&#xE5C4;" FontSize="16" />
                </Button>

                <!-- Title -->
                <TextBlock
                    Grid.Column="2"
                    Text="Galena Action Ring"
                    FontSize="14"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0" />



                
            </Grid>
        </Border>

        <!-- Main Navigation and Content -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            PaneDisplayMode="LeftCompact"
            IsSettingsVisible="False"
            AlwaysShowHeader="False"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            PaneTitle="Galena Action Ring"
            ItemInvoked="NavView_ItemInvoked"
            OpenPaneLength="280"
            BorderThickness="0"
            IsTabStop="False">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavBluetooth" Tag="Bluetooth" Content="Devices">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined" Glyph="&#xE1A7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavConfigure" Tag="Configure" Content="Configure">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined" Glyph="&#xE8B8;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="DevicesTitle" Text="Devices" FontSize="28" FontWeight="SemiBold" Margin="24,12,24,16" />

                <Grid x:Name="ContentArea" Grid.Row="1" HorizontalAlignment="Stretch" Margin="24,0,24,0">

                        <!-- ==================== CONFIGURE ==================== -->
                        <Grid x:Name="ConfigurePage" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                             <!-- Row 0: App Profile Tabs -->
                             <Grid Grid.Row="0" Padding="12,4,12,8">
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="*" />
                                     <ColumnDefinition Width="Auto" />
                                 </Grid.ColumnDefinitions>
                                 <ListView x:Name="AppProfileTabs" Grid.Column="0"
                                           SelectionMode="Single"
                                           SelectionChanged="AppProfileTabs_SelectionChanged"
                                           ScrollViewer.HorizontalScrollMode="Enabled"
                                           ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                           ScrollViewer.VerticalScrollMode="Disabled">
                                     <ListView.ItemsPanel>
                                         <ItemsPanelTemplate>
                                             <ItemsStackPanel Orientation="Horizontal" />
                                         </ItemsPanelTemplate>
                                     </ListView.ItemsPanel>
                                     <ListView.ItemTemplate>
                                         <DataTemplate>
                                             <StackPanel Orientation="Horizontal" Spacing="6" Padding="8,4,12,4">
                                                 <FontIcon FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined"
                                                           Glyph="{Binding Icon}" FontSize="14"
                                                           Foreground="{Binding IconBrush}" />
                                                 <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                                            VerticalAlignment="Center" />
                                             </StackPanel>
                                         </DataTemplate>
                                     </ListView.ItemTemplate>
                                 </ListView>
                                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                              VerticalAlignment="Center" Margin="8,0,12,0">
                                      <Button x:Name="AddRingBtn" Content="+ New Ring"
                                              FontSize="12" MinHeight="28" MinWidth="0"
                                              Padding="8,0,10,0"
                                              Click="AddRingBtn_Click" />
                                      <Button x:Name="DeleteRingBtn" Content="&#xE92E;"
                                              FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined" FontSize="14"
                                              MinWidth="0" Width="32" Height="32"
                                              Padding="0"
                                              ToolTipService.ToolTip="Delete ring"
                                              Click="DeleteRingBtn_Click" />
                                  </StackPanel>
                             </Grid>

                            <!-- Row 1: Split Pane -->
                            <Grid Grid.Row="1" Margin="24,0,24,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>

                                <!-- LEFT: Canvas -->
                                <Border Grid.Column="0" CornerRadius="12"
                                        Background="{StaticResource CanvasBackgroundBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" Margin="0,0,12,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                           <!-- Canvas header: back + title + rename -->
                                           <Grid Grid.Row="0" Padding="12,8">
                                               <Grid.ColumnDefinitions>
                                                   <ColumnDefinition Width="Auto" />
                                                   <ColumnDefinition Width="*" />
                                                   <ColumnDefinition Width="Auto" />
                                               </Grid.ColumnDefinitions>
                                               <Button x:Name="CanvasBackBtn" Grid.Column="0"
                                                       Visibility="Collapsed" Click="CanvasBackBtn_Click"
                                                       Background="Transparent" BorderThickness="0"
                                                       Width="32" Height="32">
                                                    <FontIcon FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined" Glyph="&#xE5C4;" FontSize="14" />
                                               </Button>
                                               <TextBlock x:Name="CanvasTitle" Grid.Column="1"
                                                          Text="Ring Editor" FontWeight="SemiBold"
                                                          FontSize="14" VerticalAlignment="Center"
                                                          Margin="4,0,0,0" />
                                                <Button x:Name="RenameRingBtn" Grid.Column="2"
                                                        Content="&#xF097;"
                                                        FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined" FontSize="12"
                                                       MinWidth="0" Width="28" Height="28"
                                                       Padding="0"
                                                       ToolTipService.ToolTip="Rename ring"
                                                       Click="RenameRingBtn_Click" />
                                            </Grid>

                                        <!-- Interactive Ring Canvas (scaled via Viewbox) -->
                                        <Viewbox Grid.Row="1" Stretch="Uniform"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Canvas x:Name="RingCanvas" Width="400" Height="400"
                                                    Background="Transparent"
                                                    PointerPressed="RingCanvas_PointerPressed"
                                                    PointerMoved="RingCanvas_PointerMoved"
                                                    PointerReleased="RingCanvas_PointerReleased"
                                                    PointerCanceled="RingCanvas_PointerCanceled" />
                                        </Viewbox>
                                    </Grid>
                                </Border>

                                <!-- RIGHT: Node Editor -->
                                <Grid Grid.Column="1">
                                    <!-- Default message when no node is selected -->
                                    <TextBlock x:Name="NodeEditDefaultText"
                                               Text="Click on a node to edit"
                                               VerticalAlignment="Top" HorizontalAlignment="Center"
                                               FontSize="14" Margin="0,40,0,0"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Visibility="Visible" />

                                    <!-- Node edit panel (visible when a node is selected) -->
                                    <ScrollViewer x:Name="NodeEditPanel" Visibility="Collapsed"
                                                  VerticalScrollBarVisibility="Auto" Padding="16,0,16,16">
                                        <StackPanel Spacing="12">
                                            <!-- Icon + Name preview -->
                                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                                                <Border x:Name="PropNodePreview"
                                                        Width="48" Height="48" CornerRadius="24"
                                                        Background="{StaticResource NodeFillBrush}">
                                                    <FontIcon x:Name="PropGlyphPreview"
                                                              FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined"
                                                              FontSize="22" Foreground="White"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock x:Name="PropLabelDisplay" Text=""
                                                               FontSize="14" FontWeight="SemiBold" />
                                                    <TextBlock x:Name="PropActionDisplay" Text=""
                                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Name -->
                                            <TextBox x:Name="PropLabelBox" Header="Name"
                                                     TextChanged="PropLabelBox_TextChanged" />

                                            <!-- Action Type -->
                                            <ComboBox x:Name="PropActionTypeBox" Header="Action Type"
                                                       SelectionChanged="PropActionTypeBox_SelectionChanged" />

                                            <!-- URL (visible only for OpenUrl) -->
                                            <TextBox x:Name="PropUrlBox" Header="URL"
                                                     Visibility="Collapsed"
                                                     TextChanged="PropUrlBox_TextChanged" />

                                            <!-- App Picker (visible only for LaunchApp) -->
                                            <Grid x:Name="PropAppPicker" Visibility="Collapsed" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="PropAppPathBox" Grid.Column="0"
                                                         Header="Application"
                                                         TextChanged="PropAppPathBox_TextChanged" />
                                                <Button x:Name="PropAppBrowseBtn" Grid.Column="1"
                                                        Content="Browse" Margin="8,20,0,0"
                                                        VerticalAlignment="Bottom" MinWidth="0"
                                                        Click="PropAppBrowseBtn_Click" />
                                            </Grid>

                                            <!-- Ring Colors -->
                                            <TextBlock Text="Ring Colors" FontSize="13" FontWeight="SemiBold"
                                                       Margin="0,8,0,0" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="PrimaryColorSlider" Minimum="0" Maximum="360"
                                                        Header="Primary"
                                                        ValueChanged="PrimaryColorSlider_ValueChanged" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                            VerticalAlignment="Bottom" Margin="8,0,0,8">
                                                    <Border x:Name="PrimaryPreview" Width="32" Height="32"
                                                            CornerRadius="4" Background="Black" />
                                                    <Border x:Name="SecondaryPreview" Width="32" Height="32"
                                                            CornerRadius="4" Background="Gray" Margin="4,0,0,0" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- Icon -->
                                            <TextBlock Text="Icon" FontSize="13" FontWeight="SemiBold"
                                                       Margin="0,8,0,4" />
                                            <GridView x:Name="IconGallery" Height="200"
                                                      SelectionChanged="IconGallery_SelectionChanged">
                                                <GridView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="44" Height="44" CornerRadius="8"
                                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                            <FontIcon FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined"
                                                                      Glyph="{Binding Glyph}" FontSize="22"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                        </Border>
                                                    </DataTemplate>
                                                </GridView.ItemTemplate>
                                            </GridView>

                                            <!-- Edit Sub-menu (visible for Folder) -->
                                            <Button x:Name="EditSubmenuBtn" Content="Edit Sub-menu"
                                                    Click="EditSubmenuBtn_Click"
                                                    Visibility="Collapsed" />

                                            <!-- Save -->
                                            <Button x:Name="NodeEditSaveBtn" Content="Save Changes"
                                                    HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                                    Click="NodeEditSaveBtn_Click" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- ==================== DEVICES ==================== -->
                        <ScrollViewer x:Name="BluetoothScrollViewer">
                            <Grid x:Name="BluetoothPage" Visibility="Visible">
                                <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Device Section Header -->
                            <TextBlock Grid.Row="0" Text="Device" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />

                            <!-- Device Info Card -->
                            <Border Grid.Row="1" Style="{StaticResource SettingsCardStyle}" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="8">
                                        <TextBlock x:Name="DeviceNameText" Text="Connected Action Ring Device" FontSize="18" FontWeight="SemiBold" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="Gray" VerticalAlignment="Center" />
                                            <TextBlock x:Name="StatusText" Grid.Column="1" Text="Disconnected" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </StackPanel>
                                    <Button x:Name="ConnectButton" Grid.Column="1" Content="Connect" VerticalAlignment="Center" MinWidth="100" Click="ConnectButton_Click" />
                                </Grid>
                            </Border>

                            <!-- Available Devices Section Header -->
                            <TextBlock Grid.Row="2" Text="Available devices" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8" />

                            <!-- Available Devices Card -->
                            <Border Grid.Row="3" Style="{StaticResource SettingsCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ItemsControl x:Name="DeviceListControl" Grid.Row="0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined" Glyph="{Binding IconGlyph}" Foreground="{Binding IconBrush}" FontSize="16" VerticalAlignment="Center" />
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding FriendlyName}" FontSize="14" />
                                                            <TextBlock Text="{Binding PortName}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="{Binding ButtonText}" Tag="{Binding PortName}" Click="DeviceItemConnect_Click"
                                                            Width="90" HorizontalAlignment="Stretch" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="NoDevicesText" Grid.Row="1" Text="No devices found" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,16,0,0" Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <!-- Debug Section Header -->
                            <TextBlock Grid.Row="4" Text="Debug" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8" />

                            <!-- Debug Toggle Card -->
                            <Border x:Name="DebugToggleCard" Grid.Row="5" Style="{StaticResource SettingsCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Debug" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <ToggleSwitch x:Name="DebugToggle" Grid.Column="1" Toggled="DebugToggle_Toggled" />
                                </Grid>
                            </Border>

                            <!-- Debug Content Card (separate, collapsible) -->
                            <Border x:Name="DebugContentCard" Grid.Row="6" Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,24" Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Prefix Row -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="TX prefix" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBox x:Name="TxPrefixBox" Text="→ " FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="RX prefix" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBox x:Name="RxPrefixBox" Text="← " FontSize="12" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Log Area -->
                                    <Border Grid.Row="1" Margin="0,8,0,0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" MinHeight="150" MaxHeight="400">
                                        <ScrollViewer x:Name="LogScrollView">
                                            <TextBlock x:Name="DebugLogText" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" Padding="8" IsTextSelectionEnabled="True" />
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Send Row -->
                                    <Grid Grid.Row="2" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Clear" Click="ClearLogButton_Click" Margin="0,0,8,0" />
                                        <TextBox x:Name="SendTextBox" Grid.Column="1" PlaceholderText="Data to send" />
                                        <Button x:Name="SendButton" Grid.Column="2" Content="Send" Margin="8,0,0,0" Click="SendButton_Click" />
                                    </Grid>
                                </Grid>
                            </Border>
                            </Grid>
                        </ScrollViewer>


                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
