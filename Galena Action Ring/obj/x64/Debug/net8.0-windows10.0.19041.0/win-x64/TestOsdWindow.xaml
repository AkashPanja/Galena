<Window
    x:Class="Galena_Action_Ring.TestOsdWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:ConnectionId='2' x:Name="RootGrid" Background="#FFFF00FF" Width="400" Height="400">
        <Ellipse x:ConnectionId='3' x:Name="DarkCircle" Width="340" Height="340" Fill="#CC1E1E1E"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />

        <Grid x:ConnectionId='4' x:Name="OptionsContainer" HorizontalAlignment="Center" VerticalAlignment="Center" />

        <Ellipse Width="36" Height="36" Fill="White" Stroke="#666" StrokeThickness="0"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                   Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Window>

