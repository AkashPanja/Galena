<Window
    x:Class="Galena_Action_Ring.OsdWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent" Width="400" Height="400">
        <Grid x:ConnectionId='2' x:Name="CenterButton" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <CompositeTransform x:ConnectionId='4' x:Name="CenterButtonTransform" />
            </Grid.RenderTransform>
            <Ellipse x:ConnectionId='5' x:Name="CenterEllipse" Width="36" Height="36" Fill="White" />
            <FontIcon x:ConnectionId='6' x:Name="CenterIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" Foreground="Black" FontSize="16"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <Grid x:ConnectionId='3' x:Name="OptionsContainer" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Window>

