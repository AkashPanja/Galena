<Window
    x:Class="Galena_Action_Ring.OsdWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent" Width="400" Height="400">
        <!-- Main ring options -->
        <Grid x:Name="OptionsContainer" HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Sub-menu background (radial gradient behind sub-menu nodes) -->
        <Grid x:Name="SubMenuBgLayer" Visibility="Collapsed"
              HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
            <Ellipse x:Name="SubMenuBgEllipse" Width="160" Height="160" />
        </Grid>
        <!-- Seek indicator -->
        <FontIcon x:Name="SeekIndicator" FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined"
                  Glyph="&#xEAC9;" Foreground="White" FontSize="28"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0"
                  RenderTransformOrigin="0.5,0.5">
            <FontIcon.RenderTransform>
                <CompositeTransform x:Name="SeekIndicatorTransform" TranslateX="0" />
            </FontIcon.RenderTransform>
        </FontIcon>

        <!-- Center button -->
        <Grid x:Name="CenterButton" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="CenterButtonTransform" />
            </Grid.RenderTransform>
            <Ellipse x:Name="CenterEllipse" Width="36" Height="36" Fill="White" />
            <FontIcon x:Name="CenterIcon" FontFamily="Assets/MaterialSymbols.ttf#Material Symbols Outlined"
                      Glyph="&#xE5CD;" Foreground="Black" FontSize="16"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <!-- Radial progress overlay (Volume/Brightness groups) -->
        <Grid x:Name="RadialProgressLayer" Visibility="Collapsed"
              HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="RadialTransform" />
            </Grid.RenderTransform>
            <Ellipse Width="300" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush MappingMode="Absolute" Center="150,150" GradientOrigin="150,150" RadiusX="150" RadiusY="150">
                        <RadialGradientBrush.GradientStops>
                            <GradientStop Offset="0.0" Color="#CC000000" />
                            <GradientStop Offset="1.0" Color="#00000000" />
                        </RadialGradientBrush.GradientStops>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <TextBlock x:Name="RadialLabel" Text="" FontSize="14" Foreground="#AAFFFFFF"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-80,0,0" />
            <TextBlock x:Name="RadialPercent" Text="0%" FontSize="44" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>


    </Grid>
</Window>
